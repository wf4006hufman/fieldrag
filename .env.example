# Copy to .env and fill in. Do NOT commit .env.

# --- Gemini auth ---
# Option A: Gemini Developer API key (simple local/free-tier path).
# Leave blank for public BYOK demos where visitors enter their own key in the UI.
# GEMINI_API_KEY=your-ai-studio-key

# Option B: GCP / Gemini (Agent Platform / Vertex backend via ADC).
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_VERTEXAI=true

# --- Models (verify IDs in Model Garden if a call 404s) ---
GEN_MODEL=gemini-2.5-pro
EMBED_MODEL=gemini-embedding-001
EMBED_DIM=768
TOP_K=5
REQUIRE_API_KEY_FOR_RAG=false

# --- Database: LOCAL (docker-compose) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fieldrag
DB_USER=fieldrag
DB_PASSWORD=fieldrag

# --- Database: PROD (Cloud SQL). Leave blank locally. ---
# When set, db.py connects via Unix socket /cloudsql/INSTANCE_CONNECTION_NAME
# INSTANCE_CONNECTION_NAME=your-project:asia-northeast3:fieldrag-pg
